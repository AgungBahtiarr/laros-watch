---
import Layout from "./Layout.astro";
const BASE_API_URL = import.meta.env.BASE_API_URL;
---

<Layout>
  <div class="container mx-auto max-w-5xl p-4 md:p-8">
    <header class="mb-10 text-center">
      <h1 class="text-4xl font-bold tracking-tight">Laros Watch</h1>
      <p class="text-base-content/60 mt-2">Live Network Monitoring</p>
    </header>

    <main
      id="devices-list-container"
      class="grid grid-cols-1 md:grid-cols-2 gap-4 items-start"
    >
      <div class="text-center p-8 md:col-span-2" id="initial-loader">
        <span class="loading loading-lg loading-spinner"></span>
        <p class="mt-4 text-base-content/70">Connecting to stream...</p>
      </div>
    </main>

    <footer class="mt-12 text-center text-sm text-base-content/50">
      <p>LarosNdoo...</p>
    </footer>
  </div>
</Layout>

<script define:vars={{ BASE_API_URL }}>
  document.addEventListener("DOMContentLoaded", () => {
    const sseContainer = document.getElementById("devices-list-container");
    if (!sseContainer) return;

    const eventSourceUrl = `${BASE_API_URL}/nodes/status/events`;
    if (!BASE_API_URL) {
      console.error("Base API URL is not defined!");
      displayConnectionError(
        "Configuration Error",
        "PUBLIC_BASE_API_URL is missing."
      );
      return;
    }

    const eventSource = new EventSource(eventSourceUrl);

    eventSource.onopen = () => {
      console.log("SSE connection established.");
      removeConnectionError();
    };

    eventSource.onerror = () => {
      console.error("SSE Connection Error");
      displayConnectionError("Connection Lost", "Attempting to reconnect...");
    };

    eventSource.addEventListener("update-list", (event) => {
      try {
        const nodes = JSON.parse(event.data);
        renderDeviceList(nodes);
      } catch (e) {
        console.error("Failed to parse or render SSE data:", e);
        displayConnectionError(
          "Data Error",
          "Received invalid data from server."
        );
      }
    });

    function renderDeviceList(nodes) {
      const loader = document.getElementById("initial-loader");
      if (loader) loader.remove();

      if (nodes.length === 0) {
        sseContainer.innerHTML = `<div class="text-center p-8 rounded-lg border border-dashed border-base-300 md:col-span-2">
            <h3 class="text-xl font-semibold">No Devices Found</h3>
            <p class="text-base-content/60 mt-2">The server is not monitoring any devices yet.</p>
          </div>`;
        return;
      }

      sseContainer.innerHTML = nodes.map(renderDeviceCard).join("");
    }

    function renderDeviceCard(node) {
      const statusInfo =
        node.status === 1
          ? { color: "bg-success", text: "Up" }
          : { color: "bg-error", text: "Down" };

      const interfacesHtml =
        node.interfaces?.length > 0
          ? node.interfaces.map(renderInterfaceItem).join("")
          : `<div class="p-4 text-center text-sm text-base-content/60">No interfaces to display.</div>`;

      return `
        <div class="card rounded-lg border border-base-300 bg-base-100 shadow-sm transition-all hover:shadow-md">
          <div class="card-body p-4">
            <div class="flex justify-between items-center">
              <div class="grid gap-1">
                <h2 class="font-semibold text-lg flex items-center gap-3">
                  <span>${node.name}</span>
                  <a href="#" class="text-sm font-mono accent-color">${node.ipMgmt}</a>
                </h2>
                <p class="text-sm text-base-content/60">${node.popLocation || "N/A"}</p>
              </div>
              <div class="flex items-center gap-2 text-sm font-semibold">
                <div class="w-3 h-3 rounded-full ${statusInfo.color}"></div>
                <span>${statusInfo.text}</span>
              </div>
            </div>

            <details class="accordion-item mt-2">
              <summary>Show Interfaces (${node.interfaces?.length || 0})</summary>
              <div class="accordion-content pt-2">
                <ul class="divide-y divide-base-200">${interfacesHtml}</ul>
              </div>
            </details>
          </div>
        </div>`;
    }

    function renderInterfaceItem(iface) {
      const statusInfo =
        iface.ifOperStatus === 1
          ? { class: "text-success", text: "up" }
          : { class: "text-error", text: "down" };

      const tx = iface.opticalTx ?? "N/A";
      const rx = iface.opticalRx ?? "N/A";

      return `
        <li class="py-2 px-1 flex justify-between items-center text-sm w-full">
          <div class="flex-1 truncate" title="${iface.ifDescr || iface.ifName}">
            <span class="font-mono text-xs mr-3 p-1 bg-base-200 rounded-md">${iface.ifName || "N/A"}</span>
            <span class="text-base-content/70">${iface.ifDescr || "No description"}</span>
          </div>
          <div class="flex items-center gap-4 pl-3">
            <span class="text-xs font-mono text-base-content/70" title="Rx / Tx Power">${rx} / ${tx}</span>
            <span class="font-semibold ${statusInfo.class} w-8 text-right">${statusInfo.text}</span>
          </div>
        </li>`;
    }

    function displayConnectionError(title, subtitle) {
      const loader = document.getElementById("initial-loader");
      if (loader) loader.remove();
      removeConnectionError();
      const errorMessage = document.createElement("div");
      errorMessage.className =
        "p-6 my-4 text-center text-red-800 rounded-lg bg-red-50 border border-red-200 sse-error-message md:col-span-2";
      errorMessage.setAttribute("role", "alert");
      errorMessage.innerHTML = `<h3 class="font-bold text-lg">${title}</h3><p class="text-sm">${subtitle}</p>`;
      sseContainer.prepend(errorMessage);
    }

    function removeConnectionError() {
      const oldError = sseContainer.querySelector(".sse-error-message");
      if (oldError) oldError.remove();
    }
  });
</script>
